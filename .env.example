# --- Base de données ---
# Turso (production / Vercel). Laisser vide en local pour utiliser prisma/dev.db.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
# Utilisé par les migrations Prisma et le dev local (fichier SQLite).
DATABASE_URL="file:./prisma/dev.db"

# --- Auth.js (NextAuth v5) ---
# Générer avec : npx auth secret
AUTH_SECRET=
# Google OAuth — https://console.cloud.google.com/apis/credentials (type "Web application")
# Redirect URI : https://<domaine>/api/auth/callback/google  (+ http://localhost:3000/... en dev)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Compte propriétaire : à sa première connexion, les données historiques (userId nul / "__legacy__")
# lui sont rattachées.
OWNER_EMAIL=matthieu.deroir@gmail.com
# Dev local uniquement : bypass du login Google (impossible en production).
# AUTH_DEV_BYPASS=1

# --- Mistral (correction des épreuves TORFL + recommandation) ---
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
